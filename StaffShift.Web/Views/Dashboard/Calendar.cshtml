@{
    ViewData["Title"] = "My Calendar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-calendar3 me-2 text-primary"></i>My Calendar</h1>
        <p class="text-muted mb-0">View your shifts, time off, and team schedule</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Shift" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Add Shift
        </a>
        <a asp-controller="TimeOff" asp-action="Create" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-calendar-plus me-1"></i>Request Time Off
        </a>
    </div>
</div>

<!-- Legend -->
<div class="card mb-3 border-0 shadow-sm">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <small class="text-muted fw-semibold">Legend:</small>
            <span class="badge" style="background:#3182ce">🕐 My Shift (Scheduled)</span>
            <span class="badge" style="background:#38a169">✅ Shift (Completed)</span>
            <span class="badge" style="background:#dd6b20">⏳ Shift (In Progress)</span>
            <span class="badge" style="background:#d69e2e">📅 Time Off (Pending)</span>
            <span class="badge" style="background:#805ad5">🏖️ Time Off (Approved)</span>
            <span class="badge" style="background:#e53e3e">❌ Rejected</span>
            @if (ViewBag.IsCEO == true || ViewBag.IsManager == true)
            {
                <span class="badge" style="background:#718096">👤 Team Shift</span>
                <span class="badge" style="background:#b794f4">🏖️ Team Time Off</span>
            }
        </div>
    </div>
</div>

<!-- Calendar Card -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-3">
        <div id="calendar"></div>
    </div>
</div>

<!-- Event Detail Modal -->
<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header" id="modalHeader">
                <h5 class="modal-title" id="modalTitle">Event Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                <a id="modalActionBtn" href="#" class="btn btn-primary btn-sm" style="display:none">View Details</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- FullCalendar -->
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <style>
        #calendar {
            min-height: 600px;
        }
        .fc-event {
            cursor: pointer;
            border: none !important;
            border-radius: 4px !important;
            font-size: 0.78rem !important;
            padding: 2px 4px !important;
        }
        .fc-event:hover {
            opacity: 0.85;
            transform: scale(1.01);
        }
        .fc-toolbar-title {
            font-size: 1.2rem !important;
            font-weight: 700;
        }
        .fc-button {
            background: #1a365d !important;
            border-color: #1a365d !important;
            border-radius: 6px !important;
            font-size: 0.85rem !important;
        }
        .fc-button:hover {
            background: #2c5282 !important;
        }
        .fc-button-active {
            background: #2c5282 !important;
        }
        .fc-today-button {
            background: #3182ce !important;
            border-color: #3182ce !important;
        }
        .fc-daygrid-day-today {
            background: #ebf8ff !important;
        }
        .fc-col-header-cell {
            background: #f7fafc;
            font-weight: 600;
            color: #4a5568;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');
            var modal = new bootstrap.Modal(document.getElementById('eventModal'));

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
                },
                height: 'auto',
                nowIndicator: true,
                editable: false,
                selectable: true,
                navLinks: true,
                eventSources: [
                    {
                        url: '@Url.Action("CalendarEvents", "Dashboard")',
                        method: 'GET',
                        failure: function () {
                            console.error('Failed to load calendar events');
                        }
                    }
                ],
                loading: function (isLoading) {
                    if (isLoading) {
                        calendarEl.style.opacity = '0.6';
                    } else {
                        calendarEl.style.opacity = '1';
                    }
                },
                eventClick: function (info) {
                    info.jsEvent.preventDefault();
                    showEventModal(info.event);
                },
                select: function (info) {
                    // Clicking on a date offers to create a shift
                    if (confirm('Create a new shift on ' + info.startStr + '?')) {
                        window.location.href = '@Url.Action("Create", "Shift")' + '?date=' + info.startStr;
                    }
                },
                eventMouseEnter: function (info) {
                    info.el.style.transform = 'scale(1.02)';
                    info.el.style.zIndex = '999';
                },
                eventMouseLeave: function (info) {
                    info.el.style.transform = '';
                    info.el.style.zIndex = '';
                },
                dayCellDidMount: function (info) {
                    // Highlight today
                    if (info.isToday) {
                        info.el.style.background = '#ebf8ff';
                    }
                }
            });

            calendar.render();

            function showEventModal(event) {
                var props = event.extendedProps;
                var type = props.type || 'event';
                var headerColor = event.backgroundColor || '#3182ce';

                document.getElementById('modalHeader').style.background = headerColor;
                document.getElementById('modalHeader').style.color = '#fff';
                document.getElementById('modalTitle').textContent = event.title;

                var bodyHtml = '';
                var startDate = event.start ? formatDate(event.start) : '';
                var endDate = event.end ? formatDate(new Date(event.end - 86400000)) : startDate;

                if (type === 'shift' || type === 'team-shift') {
                    var memberLabel = props.memberName ? '<tr><td class="text-muted pe-3">Employee</td><td><strong>' + props.memberName + '</strong></td></tr>' : '';
                    bodyHtml = '<table class="table table-sm table-borderless mb-0">' +
                        memberLabel +
                        '<tr><td class="text-muted pe-3">Date</td><td><strong>' + startDate + '</strong></td></tr>' +
                        '<tr><td class="text-muted pe-3">Time</td><td><strong>' + formatTime(event.start) + (event.end ? ' – ' + formatTime(event.end) : '') + '</strong></td></tr>' +
                        '<tr><td class="text-muted pe-3">Status</td><td><span class="badge bg-primary">' + (props.status || 'Scheduled') + '</span></td></tr>' +
                        (props.location ? '<tr><td class="text-muted pe-3">Location</td><td>' + props.location + '</td></tr>' : '') +
                        '</table>';
                } else if (type === 'timeoff' || type === 'team-timeoff') {
                    var memberLabel2 = props.memberName ? '<tr><td class="text-muted pe-3">Employee</td><td><strong>' + props.memberName + '</strong></td></tr>' : '';
                    var paidLabel = props.requestType === 'Sick' ? '<tr><td class="text-muted pe-3">Pay Type</td><td><span class="badge ' + (props.isPaid ? 'bg-success' : 'bg-danger') + '">' + (props.isPaid ? 'Paid' : 'Unpaid') + '</span></td></tr>' : '';
                    bodyHtml = '<table class="table table-sm table-borderless mb-0">' +
                        memberLabel2 +
                        '<tr><td class="text-muted pe-3">Type</td><td><strong>' + (props.requestType || 'Time Off') + '</strong></td></tr>' +
                        '<tr><td class="text-muted pe-3">From</td><td>' + startDate + '</td></tr>' +
                        '<tr><td class="text-muted pe-3">To</td><td>' + endDate + '</td></tr>' +
                        paidLabel +
                        '<tr><td class="text-muted pe-3">Status</td><td><span class="badge ' + getStatusBadge(props.status) + '">' + (props.status || 'Pending') + '</span></td></tr>' +
                        '</table>';
                }

                document.getElementById('modalBody').innerHTML = bodyHtml;

                // Show action button for own time off
                if (type === 'timeoff') {
                    var id = event.id.replace('timeoff-', '');
                    document.getElementById('modalActionBtn').href = '@Url.Action("Details", "TimeOff")/' + id;
                    document.getElementById('modalActionBtn').style.display = 'inline-block';
                } else if (type === 'shift') {
                    var shiftId = event.id.replace('shift-', '');
                    document.getElementById('modalActionBtn').href = '@Url.Action("Details", "Shift")/' + shiftId;
                    document.getElementById('modalActionBtn').style.display = 'inline-block';
                } else {
                    document.getElementById('modalActionBtn').style.display = 'none';
                }

                modal.show();
            }

            function formatDate(d) {
                if (!d) return '';
                return d.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });
            }

            function formatTime(d) {
                if (!d) return '';
                return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
            }

            function getStatusBadge(status) {
                switch (status) {
                    case 'Approved': return 'bg-success';
                    case 'Rejected': return 'bg-danger';
                    case 'Cancelled': return 'bg-secondary';
                    default: return 'bg-warning text-dark';
                }
            }
        });
    </script>
}