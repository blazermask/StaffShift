@model IEnumerable<UserDto>
@{
    ViewData["Title"] = "Manage Employees";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-people me-2"></i>Employees</h1>
        <p class="text-muted mb-0">Manage all employees in the organization</p>
    </div>
    <a asp-action="CreateEmployee" class="btn btn-primary">
        <i class="bi bi-person-plus me-2"></i>Add Employee
    </a>
</div>

<div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Total Employees</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card success">
            <div class="stat-icon"><i class="bi bi-person-badge"></i></div>
            <div class="stat-value">@Model.Count(u => u.Roles.Contains("Manager"))</div>
            <div class="stat-label">Managers</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card info">
            <div class="stat-icon"><i class="bi bi-person"></i></div>
            <div class="stat-value">@Model.Count(u => u.Roles.Contains("Worker") && !u.Roles.Contains("Manager"))</div>
            <div class="stat-label">Workers</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card warning">
            <div class="stat-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <div class="stat-value">@Model.Count(u => u.ManagerId == null && u.Roles.Contains("Worker"))</div>
            <div class="stat-label">Unassigned</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Position</th>
                            <th>Role</th>
                            <th>Manager</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model.OrderBy(e => e.LastName).ThenBy(e => e.FirstName))
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 36px; height: 36px;">
                                            @(employee.FirstName?.Substring(0, 1) ?? "?")@(employee.LastName?.Substring(0, 1) ?? "?")
                                        </div>
                                        <div>
                                            <strong>@employee.FirstName @employee.LastName</strong>
                                            <br><small class="text-muted">@employee.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@(employee.Department ?? "-")</td>
                                <td>@(employee.Position ?? "-")</td>
                                <td>
                                    @if (employee.Roles != null)
                                    {
                                        foreach (var role in employee.Roles)
                                        {
                                            <span class="badge @(role == "CEO" ? "bg-danger" : role == "Manager" ? "bg-success" : "bg-info")">@role</span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (employee.ManagerId.HasValue)
                                    {
                                        <span>@employee.ManagerName</span>
                                    }
                                    else if (employee.Roles?.Contains("Worker") == true)
                                    {
                                        <span class="badge bg-warning">Unassigned</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditEmployee" asp-route-id="@employee.Id" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (!employee.Roles?.Contains("CEO") == true)
                                        {
                                            <form asp-action="DeleteEmployee" asp-route-id="@employee.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger" title="Delete" onclick="return confirm('Delete this employee?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <h5>No Employees</h5>
                <p>Start by adding your first employee.</p>
                <a asp-action="CreateEmployee" class="btn btn-primary">
                    <i class="bi bi-person-plus me-2"></i>Add Employee
                </a>
            </div>
        }
    </div>
</div>