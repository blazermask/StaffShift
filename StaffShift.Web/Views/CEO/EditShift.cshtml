@model StaffShift.Core.DTOs.UpdateShiftDto
@{
    ViewData["Title"] = "Edit Shift";
}

<div class="page-header">
    <h1><i class="bi bi-pencil me-2"></i>Edit Shift</h1>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="EditShift" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ShiftDate" class="form-label">Shift Date</label>
                            <input asp-for="ShiftDate" class="form-control" type="date" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Scheduled">Scheduled</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Completed">Completed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartTime" class="form-label">Start Time</label>
                            <input asp-for="StartTime" class="form-control" type="time" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndTime" class="form-label">End Time</label>
                            <input asp-for="EndTime" class="form-control" type="time" required />
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                        <a asp-action="Calendar" class="btn btn-outline-secondary">Cancel</a>
                        <form asp-action="DeleteShift" method="post" class="ms-auto">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this shift?')">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </form>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}