@model StaffShift.Core.DTOs.CreateShiftDto
@{
    ViewData["Title"] = "Assign Manager Shifts";
    var managers = ViewBag.Managers as IEnumerable<StaffShift.Core.DTOs.UserDto>;
}

<div class="page-header">
    <h1><i class="bi bi-calendar-plus me-2"></i>Assign Manager Shifts</h1>
    <p class="text-muted mb-0">Assign shifts to managers</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">New Shift</h5>
            </div>
            <div class="card-body">
                <form asp-action="AssignShift" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UserId" class="form-label">Manager</label>
                            <select asp-for="UserId" class="form-select" required>
                                <option value="">Select Manager</option>
                                @if (managers != null)
                                {
                                    foreach (var manager in managers)
                                    {
                                        <option value="@manager.Id">@manager.FirstName @manager.LastName (@manager.Username)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ShiftDate" class="form-label">Shift Date</label>
                            <input asp-for="ShiftDate" class="form-control" type="date" required />
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartTime" class="form-label">Start Time</label>
                            <input asp-for="StartTime" class="form-control" type="time" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndTime" class="form-label">End Time</label>
                            <input asp-for="EndTime" class="form-control" type="time" required />
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Notes (Optional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Assign Shift
                        </button>
                        <a asp-action="Calendar" class="btn btn-outline-secondary">View Calendar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}