@model IEnumerable<DepartmentViewModel>
@{
    ViewData["Title"] = "Departments";
}

<div class="page-header">
    <h1><i class="bi bi-diagram-3 me-2"></i>Departments</h1>
    <p class="text-muted mb-0">Overview of all departments in the organization</p>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="bi bi-diagram-3"></i></div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Departments</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card success">
            <div class="stat-icon"><i class="bi bi-person-badge"></i></div>
            <div class="stat-value">@Model.Sum(d => d.ManagerCount)</div>
            <div class="stat-label">Total Managers</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card warning">
            <div class="stat-icon"><i class="bi bi-exclamation-triangle"></i></div>
            <div class="stat-value">@Model.Sum(d => d.WorkersWithoutManager)</div>
            <div class="stat-label">Unassigned Workers</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Department</th>
                            <th>Employees</th>
                            <th>Managers</th>
                            <th>Unassigned Workers</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dept in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@dept.Name</strong>
                                </td>
                                <td>@dept.EmployeeCount</td>
                                <td>@dept.ManagerCount</td>
                                <td>
                                    @if (dept.WorkersWithoutManager > 0)
                                    {
                                        <span class="badge bg-warning">@dept.WorkersWithoutManager</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Employees" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-people me-1"></i>View Employees
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-diagram-3"></i>
                <h5>No Departments</h5>
                <p>Departments will appear here once employees are assigned to them.</p>
            </div>
        }
    </div>
</div>