@model CreateTimeOffRequestDto
@{
    ViewData["Title"] = "Request Time Off";
}

<div class="page-header">
    <h1><i class="bi bi-calendar-x me-2"></i>Request Time Off</h1>
    <p class="text-muted mb-0">Submit your vacation, sick, or personal time request</p>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="RequestType" class="form-label fw-semibold">Request Type</label>
                        <select asp-for="RequestType" class="form-select" id="requestTypeSelect">
                            <option value="Vacation">🏖️ Vacation</option>
                            <option value="Sick">🏥 Sick Leave</option>
                            <option value="Personal">👤 Personal Time</option>
                            <option value="Other">📅 Other</option>
                        </select>
                        <span asp-validation-for="RequestType" class="text-danger"></span>
                    </div>

                    <!-- Paid/Unpaid Vacation - only shows for Vacation -->
                    <div class="mb-3" id="vacationPaySection" style="display:none">
                        <label class="form-label fw-semibold">Vacation Type</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="IsPaid" id="isPaidTrue" value="true" checked />
                                <label class="form-check-label" for="isPaidTrue">
                                    <span class="badge bg-success me-1">Paid</span>
                                    <small class="text-muted">Uses paid vacation allowance</small>
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="IsPaid" id="isPaidFalse" value="false" />
                                <label class="form-check-label" for="isPaidFalse">
                                    <span class="badge bg-danger me-1">Unpaid</span>
                                    <small class="text-muted">No deduction from allowance</small>
                                </label>
                            </div>
                        </div>
                        <div id="paidVacationRemaining" class="mt-2"></div>
                    </div>

                    <!-- Sick Leave Info - always paid -->
                    <div class="mb-3" id="sickInfoSection" style="display:none">
                        <div class="alert alert-info py-2 px-3 mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            <strong>Sick Leave is always paid.</strong>
                            <span id="sickDaysRemainingText"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label fw-semibold">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label fw-semibold">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="EndDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div id="dayCountBadge" class="alert alert-info py-2 px-3 mb-2" style="display:none">
                            <i class="bi bi-info-circle me-1"></i>
                            <span id="dayCountText"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Reason" class="form-label fw-semibold">Reason <small class="text-muted">(optional)</small></label>
                        <textarea asp-for="Reason" class="form-control" rows="3"
                                  placeholder="Please provide a brief explanation..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send me-2"></i>Submit Request
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card bg-light border-0 shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-info-circle me-2 text-primary"></i>Request Guidelines</h5>
                <ul class="mb-0 small">
                    <li class="mb-1"><strong>🏖️ Vacation (Paid):</strong> Uses your annual paid vacation allowance (20 days/year).</li>
                    <li class="mb-1"><strong>🏖️ Vacation (Unpaid):</strong> No pay deduction from allowance; manager approval required.</li>
                    <li class="mb-1"><strong>🏥 Sick Leave:</strong> Always paid (10 days/year allowance).</li>
                    <li class="mb-1"><strong>👤 Personal:</strong> Provide at least 48 hours notice (5 days/year).</li>
                    <li>Your manager will review and approve or reject the request.</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-calendar-check me-2 text-success"></i>Your Time Off Balance (@DateTime.Now.Year)
            </div>
            <div class="card-body p-0">
                @if (ViewBag.TimeOffSummary != null)
                {
                    var summary = (StaffShift.Core.DTOs.TimeOffSummaryDto)ViewBag.TimeOffSummary;
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <td><i class="bi bi-sun me-1 text-warning"></i>Vacation <span class="badge bg-success ms-1">Paid</span></td>
                                <td class="text-end">
                                    <span class="badge bg-primary">@summary.VacationPaidDaysRemaining remaining</span>
                                    <small class="text-muted ms-1">/ @summary.VacationPaidDaysTotal</small>
                                </td>
                            </tr>
                            <tr class="table-danger">
                                <td><i class="bi bi-sun me-1 text-warning"></i>Vacation <span class="badge bg-danger ms-1">Unpaid</span></td>
                                <td class="text-end">
                                    <span class="badge bg-secondary">@summary.VacationUnpaidDaysUsed used</span>
                                </td>
                            </tr>
                            <tr class="table-success">
                                <td><i class="bi bi-hospital me-1 text-success"></i>Sick Leave <span class="badge bg-success ms-1">Paid</span></td>
                                <td class="text-end">
                                    <span class="badge bg-success">@summary.SickDaysRemaining remaining</span>
                                    <small class="text-muted ms-1">/ @summary.SickDaysTotal</small>
                                </td>
                            </tr>
                            <tr>
                                <td><i class="bi bi-person me-1 text-info"></i>Personal</td>
                                <td class="text-end">
                                    <span class="badge bg-info">@summary.PersonalDaysRemaining remaining</span>
                                    <small class="text-muted ms-1">/ @summary.PersonalDaysTotal</small>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0 small">Balance info will appear once requests have been approved.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var vacationPaidRemaining = @(ViewBag.TimeOffSummary != null ? ((StaffShift.Core.DTOs.TimeOffSummaryDto)ViewBag.TimeOffSummary).VacationPaidDaysRemaining : 20);
        var sickDaysRemaining = @(ViewBag.TimeOffSummary != null ? ((StaffShift.Core.DTOs.TimeOffSummaryDto)ViewBag.TimeOffSummary).SickDaysRemaining : 10);

        var typeSelect = document.getElementById('requestTypeSelect');
        var vacationSection = document.getElementById('vacationPaySection');
        var sickSection = document.getElementById('sickInfoSection');

        function toggleSections() {
            if (typeSelect.value === 'Vacation') {
                vacationSection.style.display = 'block';
                sickSection.style.display = 'none';
                document.getElementById('paidVacationRemaining').innerHTML =
                    '<small class="text-success"><i class="bi bi-info-circle me-1"></i>You have <strong>' + vacationPaidRemaining + '</strong> paid vacation days remaining.</small>';
            } else if (typeSelect.value === 'Sick') {
                vacationSection.style.display = 'none';
                sickSection.style.display = 'block';
                document.getElementById('sickDaysRemainingText').textContent = 'You have ' + sickDaysRemaining + ' sick days remaining.';
            } else {
                vacationSection.style.display = 'none';
                sickSection.style.display = 'none';
            }
        }

        typeSelect.addEventListener('change', toggleSections);
        toggleSections();

        // Day count calculator
        var startInput = document.getElementById('StartDate');
        var endInput = document.getElementById('EndDate');

        function updateDayCount() {
            var start = new Date(startInput.value);
            var end = new Date(endInput.value);
            if (!isNaN(start) && !isNaN(end) && end >= start) {
                var days = Math.floor((end - start) / 86400000) + 1;
                document.getElementById('dayCountText').textContent = days + ' day' + (days > 1 ? 's' : '') + ' requested';
                document.getElementById('dayCountBadge').style.display = 'block';
            } else {
                document.getElementById('dayCountBadge').style.display = 'none';
            }
        }

        startInput.addEventListener('change', function () {
            if (!endInput.value || endInput.value < this.value)
                endInput.value = this.value;
            endInput.min = this.value;
            updateDayCount();
        });
        endInput.addEventListener('change', updateDayCount);
    </script>
}