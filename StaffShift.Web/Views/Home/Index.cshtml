@{
    ViewData["Title"] = "Welcome";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-lg-6 text-center">
        <div class="mb-4">
            <i class="bi bi-clock-history text-primary" style="font-size: 5rem;"></i>
        </div>
        <h1 class="display-4 mb-3">StaffShift</h1>
        <p class="lead text-muted mb-4">
            Your comprehensive Shift & Staff Management System. 
            Track shifts, manage time off requests, and collaborate with your team.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-4">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </a>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-calendar-week fs-3"></i>
                </div>
                <h5>Shift Management</h5>
                <p class="text-muted">Schedule and track your work shifts with easy clock in/out functionality.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
                <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-calendar-x fs-3"></i>
                </div>
                <h5>Time Off Requests</h5>
                <p class="text-muted">Request vacation, sick days, and personal time with manager approval workflow.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
                <div class="bg-info text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-chat-square-text fs-3"></i>
                </div>
                <h5>Team Forum</h5>
                <p class="text-muted">Exchange information and collaborate with your colleagues in the forum.</p>
            </div>
        </div>
    </div>
</div>