@model IEnumerable<StaffShift.Core.DTOs.ShiftDto>
@{
    ViewData["Title"] = "Team Shifts";
}

<div class="page-header">
    <h1><i class="bi bi-people me-2"></i>Team Shifts</h1>
    <p class="text-muted mb-0">View your team's scheduled shifts</p>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Shifts for @ViewBag.SelectedDate.ToString("MMM dd, yyyy")</h5>
        <div>
            <a asp-action="AssignShifts" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle me-1"></i>Assign New Shift
            </a>
        </div>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3 mb-4">
            <div class="col-auto">
                <input type="date" name="date" value="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">Filter</button>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Date</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Hours</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var shift in Model)
                        {
                            <tr>
                                <td>@shift.UserName</td>
                                <td>@shift.ShiftDate.ToString("MMM dd, yyyy")</td>
                                <td>@shift.StartTime</td>
                                <td>@shift.EndTime</td>
                                <td>@shift.HoursWorked.ToString("F1")h</td>
                                <td>
                                    <span class="badge bg-@(shift.Status == "Completed" ? "success" : shift.Status == "In Progress" ? "warning" : "secondary")">@shift.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-calendar-x"></i>
                <h5>No Shifts Scheduled</h5>
                <p>Your team has no scheduled shifts for this date.</p>
            </div>
        }
    </div>
</div>