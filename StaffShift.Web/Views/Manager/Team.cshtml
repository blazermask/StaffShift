@model IEnumerable<TeamMemberViewModel>
@{
    ViewData["Title"] = "My Team";
    var isCEO = User.IsInRole("CEO");
}

<div class="page-header">
    <h1><i class="bi bi-people me-2"></i>@(isCEO ? "All Employees" : "My Team")</h1>
    <p class="text-muted mb-0">Manage your team members and view their information</p>
</div>

<div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card primary">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Team Members</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card success">
            <div class="stat-icon"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-value">@Model.Sum(m => m.TotalShifts)</div>
            <div class="stat-label">Total Shifts</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card warning">
            <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
            <div class="stat-value">@Model.Sum(m => m.PendingTimeOffRequests)</div>
            <div class="stat-label">Pending Requests</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="stat-card info">
            <div class="stat-icon"><i class="bi bi-building"></i></div>
            <div class="stat-value">@Model.Select(m => m.User.Department).Distinct().Count()</div>
            <div class="stat-label">Departments</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Team Members</h5>
        @if (isCEO)
        {
            <a asp-controller="CEO" asp-action="AssignManager" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-link-45deg me-1"></i>Assign Managers
            </a>
        }
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Position</th>
                            <th>Manager</th>
                            <th>Shifts</th>
                            <th>Pending</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 36px; height: 36px;">
                                            @member.User.FirstName?.Substring(0, 1)@member.User.LastName?.Substring(0, 1)
                                        </div>
                                        <div>
                                            <strong>@member.User.FirstName @member.User.LastName</strong>
                                            <br><small class="text-muted">@member.User.Email</small>
                                        </div>
                                    </div>
                                </td>
                                <td>@(member.User.Department ?? "-")</td>
                                <td>@(member.User.Position ?? "-")</td>
                                <td>@(member.User.ManagerName ?? "-")</td>
                                <td><span class="badge bg-info">@member.TotalShifts</span></td>
                                <td>
                                    @if (member.PendingTimeOffRequests > 0)
                                    {
                                        <span class="badge bg-warning">@member.PendingTimeOffRequests</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Member" asp-route-id="@member.User.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <h5>No Team Members</h5>
                <p>You don't have any team members assigned yet.</p>
            </div>
        }
    </div>
</div>