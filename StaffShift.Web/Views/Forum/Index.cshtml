@model IEnumerable<ForumPostDto>
@{
    ViewData["Title"] = "Forum";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-chat-square-text me-2"></i>Forum</h1>
        <p class="text-muted mb-0">Exchange work information with your colleagues</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>New Post
    </a>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="d-flex gap-2 mb-3">
            <a asp-action="Index" class="btn @(string.IsNullOrEmpty(ViewBag.CurrentDepartment?.ToString()) ? "btn-primary" : "btn-outline-primary")">
                All Posts
            </a>
            @if (!string.IsNullOrEmpty(ViewBag.UserDepartment?.ToString()))
            {
                <a asp-action="Index" asp-route-department="@ViewBag.UserDepartment" 
                   class="btn @(ViewBag.CurrentDepartment?.ToString() == ViewBag.UserDepartment?.ToString() ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-building me-1"></i>@ViewBag.UserDepartment
                </a>
            }
        </div>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="MyPosts" class="btn btn-outline-secondary">
            <i class="bi bi-person-lines-fill me-1"></i>My Posts
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            @foreach (var post in Model)
            {
                <div class="forum-post @(post.IsPinned ? "pinned" : "") @(post.IsLocked ? "locked" : "") p-3 border-bottom">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                @if (post.IsPinned)
                                {
                                    <span class="badge bg-warning"><i class="bi bi-pin-angle me-1"></i>Pinned</span>
                                }
                                @if (post.IsLocked)
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-lock me-1"></i>Locked</span>
                                }
                                @if (!string.IsNullOrEmpty(post.Department))
                                {
                                    <span class="badge bg-info">@post.Department</span>
                                }
                            </div>
                            <h5 class="mb-1">
                                <a asp-action="Details" asp-route-id="@post.Id" class="text-decoration-none">
                                    @post.Title
                                </a>
                            </h5>
                            <p class="text-muted mb-2">@(post.Content.Length > 150 ? post.Content.Substring(0, 150) + "..." : post.Content)</p>
                            <div class="d-flex align-items-center gap-3 text-muted small">
                                <span><i class="bi bi-person me-1"></i>@post.AuthorName</span>
                                <span><i class="bi bi-calendar me-1"></i>@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                <span><i class="bi bi-chat me-1"></i>@post.CommentCount comment@(post.CommentCount != 1 ? "s" : "")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-chat-square-text"></i>
                <h5>No Forum Posts</h5>
                <p>Be the first to start a discussion!</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Create First Post
                </a>
            </div>
        }
    </div>
</div>