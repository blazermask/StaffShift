@model IEnumerable<ForumPostDto>
@{
    ViewData["Title"] = "My Forum Posts";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-person-lines-fill me-2"></i>My Forum Posts</h1>
        <p class="text-muted mb-0">Manage your forum contributions</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>New Post
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Department</th>
                            <th>Comments</th>
                            <th>Posted</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@post.Id" class="text-decoration-none">
                                        @post.Title
                                    </a>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(post.Department))
                                    {
                                        <span class="badge bg-info">@post.Department</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">All</span>
                                    }
                                </td>
                                <td>@post.CommentCount</td>
                                <td>@post.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (post.IsPinned)
                                    {
                                        <span class="badge bg-warning me-1"><i class="bi bi-pin-angle"></i></span>
                                    }
                                    @if (post.IsLocked)
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-lock"></i></span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@post.Id" class="btn btn-outline-primary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@post.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-outline-danger" title="Delete" onclick="return confirm('Delete this post?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-chat-square-text"></i>
                <h5>No Posts Yet</h5>
                <p>You haven't created any forum posts.</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-2"></i>Create Your First Post
                </a>
            </div>
        }
    </div>
</div>